# ===========================================
# SafeStep Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ===========================================
# SUPABASE CONFIGURATION (Required)
# ===========================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key - safe to use in client apps
# This key has Row Level Security (RLS) enabled
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# MAPBOX CONFIGURATION (Required for routing)
# ===========================================
# Get your token from: https://account.mapbox.com/access-tokens/

# Public access token for Mapbox Geocoding & Directions API
MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoieW91ci11c2VybmFtZSIsImEiOiJ...

# Secret download token (sk.*) for the native @rnmapbox/maps SDK. Used by
# app.config.js at build time only, never at runtime. Required for native
# (EAS) builds; leave empty for Expo Go / web.
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=

# ===========================================
# SENTRY (Crash reporting - optional but recommended for production)
# ===========================================
# DSN read by src/config/env.js and src/config/sentry.js. Leave empty to
# disable crash reporting. SENTRY_ORG / SENTRY_PROJECT (used by app.config.js
# for source-map upload) default to "safestep" / "react-native".
SENTRY_DSN=

# ===========================================
# NYC OPEN DATA
# ===========================================
# The mobile app does NOT read a NYC Open Data token. The Socrata app token is
# a backend-only value: see NYC_OPEN_DATA_APP_TOKEN in backend/.env.example.

# ===========================================
# APP CONFIGURATION
# ===========================================

# NOTE: The app version is NOT set here. It is sourced from package.json and
# wired into the app by app.config.js (both `version` and extra.APP_VERSION).
# src/config/env.js reads it from Constants.expoConfig.extra.APP_VERSION.

# Environment mode
NODE_ENV=development

# Routing backend base URL (read by src/config/env.js as ROUTING_API_URL).
# Defaults to http://localhost:8000 in dev; set the production URL for a build.
ROUTING_API_URL=

# ===========================================
# FEATURE FLAGS
# ===========================================

# Enable analytics tracking
ENABLE_ANALYTICS=true

# Enable Guardian subscription features
ENABLE_GUARDIAN_SUBSCRIPTION=false

# Enable debug mode (extra logging)
DEBUG_MODE=true

# ===========================================
# OPTIONAL: PUSH NOTIFICATIONS
# ===========================================
# For Expo push notifications (optional)
# EXPO_PUSH_TOKEN=ExponentPushToken[...]

# ===========================================
# OPTIONAL: STRIPE (for subscriptions)
# ===========================================
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_... # Only use on server!

# ===========================================
# SETUP INSTRUCTIONS
# ===========================================
# 
# 1. SUPABASE SETUP:
#    a. Create project at https://supabase.com
#    b. Go to Project Settings > API
#    c. Copy "Project URL" → SUPABASE_URL
#    d. Copy "anon public" key → SUPABASE_ANON_KEY
#    e. Run the schema.sql in SQL Editor
#
# 2. MAPBOX SETUP:
#    a. Create account at https://www.mapbox.com
#    b. Go to Account > Access Tokens
#    c. Create token with: Geocoding, Directions API scopes
#    d. Copy token → MAPBOX_ACCESS_TOKEN
#
# 3. EXPO SETUP:
#    a. Update app.config.js with your app details
#    b. Run: npx expo start
#
