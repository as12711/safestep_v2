# SafeStep Routing Backend — environment template
# Copy to .env (gitignored) or inject these via your host's secret manager.
# Read by routing/config.py. Do not commit real secrets.

# --- Area / cache -----------------------------------------------------------
# Area the pilot serves (must match a key in graph_manager.AREA_CONFIGS).
SAFESTEP_AREA=nyu
# Durable cache root. In the container this is the mounted volume (/app/cache);
# locally it defaults to .safestep_cache if unset.
SAFESTEP_CACHE_DIR=/app/cache

# --- CORS -------------------------------------------------------------------
# Comma-separated browser origins allowed to call the API. Empty is correct for
# the mobile-only pilot (the React Native app sends no Origin header).
CORS_ALLOW_ORIGINS=

# --- Risk refresh -----------------------------------------------------------
# Minutes between scheduled risk-data refreshes.
RISK_REFRESH_MINUTES=15

# --- NYC Open Data ----------------------------------------------------------
# Socrata app token (https://data.cityofnewyork.us/profile/edit/developer_settings).
# Strongly recommended: avoids the shared anonymous throttling pool.
NYC_OPEN_DATA_APP_TOKEN=

# --- Supabase (read-only, for the P1-1 verified-report pull) ----------------
# The backend reads verified rows from the public `reports` table via PostgREST.
SUPABASE_URL=
SUPABASE_ANON_KEY=
